# ----- ShipLogix frontend env -----
# Copy to .env.local in the frontend/ directory.

# Backend API base URL (no trailing slash). Leave blank to use Vite proxy in dev.
VITE_API_URL=

# Supabase project credentials (browser-safe).
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Optional Stripe public key for client-side redirect helpers.
VITE_STRIPE_PUBLIC_KEY=
