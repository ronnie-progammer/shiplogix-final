# ----- ShipLogix backend env -----
# Copy to .env in the backend/ directory. Do not commit .env.

# CORS — comma-separated list of frontend origins.
CORS_ORIGINS=http://localhost:5173,https://shiplogix.dev

# ----- Auth (Supabase) -----
# JWT secret for verifying Supabase-issued access tokens.
# Find in Supabase dashboard → Project Settings → API → JWT Secret.
SUPABASE_JWT_SECRET=
# Set to 1 in production; 0 in dev allows anonymous fallback access.
AUTH_REQUIRED=0
# Tier returned for the dev anonymous user when AUTH_REQUIRED=0.
DEV_DEFAULT_TIER=pro

# ----- Billing (Stripe) -----
# Server-side secret key (sk_live_... or sk_test_...).
STRIPE_SECRET_KEY=
# Webhook signing secret for /api/billing/webhook (whsec_...).
STRIPE_WEBHOOK_SECRET=
# Price IDs for each subscription tier.
STRIPE_PRICE_PRO=price_xxx_pro
STRIPE_PRICE_BUSINESS=price_xxx_business
# Redirect targets after Checkout / Customer Portal.
STRIPE_SUCCESS_URL=https://shiplogix.dev/billing?status=success
STRIPE_CANCEL_URL=https://shiplogix.dev/billing?status=cancel
STRIPE_PORTAL_RETURN_URL=https://shiplogix.dev/billing
# Optional: pinned customer for the demo portal session.
STRIPE_DEMO_CUSTOMER=

# ----- Email (Resend) -----
RESEND_API_KEY=
EMAIL_FROM=ShipLogix <noreply@shiplogix.dev>

# ----- Carrier APIs (f1) -----
FEDEX_API_KEY=
UPS_API_KEY=
USPS_API_KEY=
DHL_API_KEY=
